# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pmerj_db?schema=public"
# Alternativa para rodar via Docker interno (ver docker-compose.yml):
# DATABASE_URL="postgresql://pmerj_user:super_senha_segura@db:5432/pmerj_db?schema=public"

# Chave secreta para assinar os tokens JWT (Sessões)
# IMPORTANTE: Gere uma nova chave forte para produção!
JWT_SECRET="sua_chave_secreta_jwt_deve_ter_pelo_menos_32_caracteres"

# Token administrativo (opcional, dependendo de como você gerencia admins)
ADMIN_TOKEN="super_secret_admin_token"

# Chaves de API para os Agentes de IA
GROQ_API_KEY="gsk_sua_chave_groq_aqui"
GROQ_MODEL="llama-3.3-70b-versatile"
